# ─── TeamClaw config example ───────────────────────────────────
# Copy to team.env, fill in values, then run:
#   bash setup-org.sh --config team.env

AGENT_NAME="Pulse"
AGENT_EMOJI="💚"
ORG_NAME="YourOrg"
PRODUCT_DESC="Your product in one line"
TEAM_TZ="Asia/Kolkata"

GH_ORG="your-github-org"
GH_PROFILE="yourorg"
GH_TOKEN=""                        # optional GitHub PAT

OPT_DOCKER="n"
OPENAI_KEY=""                      # optional, for memory search
BRAVE_KEY=""                       # optional, for web search

CLOUDFLARE_TUNNEL_TOKEN=""         # from Cloudflare Zero Trust dashboard

INSTALL_WATCHCLAW="y"
WATCHCLAW_TELEGRAM_TOKEN=""        # bot token from @BotFather
WATCHCLAW_CHAT_ID=""               # Telegram group/chat ID

INSTALL_HINDSIGHT="y"
