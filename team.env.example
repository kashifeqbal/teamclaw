# ─── TeamClaw config example ────────────────────────────────────────────────
# Copy to team.env, fill in values, then run:
#   bash setup-org.sh --config team.env
#
# All fields are optional unless marked (required).
# ─────────────────────────────────────────────────────────────────────────────

# ── Agent (required) ─────────────────────────────────────────────────────────
AGENT_NAME="Pulse"                         # Display name of your AI agent
AGENT_EMOJI="💚"                           # Emoji shown in summaries/logs
ORG_NAME="YourOrg"                         # Your company/team name
PRODUCT_DESC="Your product in one line"    # One-liner: what the product does
TEAM_TZ="Asia/Kolkata"                     # Team timezone (TZ database name)

# ── GitHub ────────────────────────────────────────────────────────────────────
GH_ORG=""                                  # GitHub org or username (blank = skip)
GH_PROFILE=""                              # Short profile name, e.g. "taphealth"
GH_TOKEN=""                                # Fine-grained PAT (blank = skip auth)

# ── Telegram — Agent bot (for DMs with your team) ────────────────────────────
# Get a bot token from @BotFather on Telegram.
PULSE_TELEGRAM_BOT_TOKEN=""                # Bot token from @BotFather
PULSE_ALLOW_FROM=""                        # Comma-separated Telegram user IDs
                                           # e.g. "111111,222222,333333"
                                           # Leave blank = allow any paired user

# ── Telegram — Ops/alerts bot (for security & ops group) ─────────────────────
# Create a second bot from @BotFather. Add it to your ops group and get the chat ID.
# If blank, falls back to PULSE_TELEGRAM_BOT_TOKEN for alerts.
OPS_TELEGRAM_BOT_TOKEN=""                  # Second bot token (ops/alerts only)
OPS_TELEGRAM_CHAT_ID=""                    # Group chat ID, e.g. "-5084525213"
OPS_ALLOW_FROM=""                          # Comma-separated allowed user IDs
                                           # for ops bot DMs

# ── Optional integrations ─────────────────────────────────────────────────────
OPT_DOCKER="n"                             # Install Docker? y/n
OPENAI_KEY=""                              # OpenAI API key — for memory embeddings
BRAVE_KEY=""                               # Brave Search API key — for web search

# ── Discord ───────────────────────────────────────────────────────────────────
# For dev team channel access. Creates a separate {agent}-discord agent.
# Create a Discord bot at https://discord.com/developers/applications
# → Bot → Token. Add to server, enable Message Content Intent.
DISCORD_BOT_TOKEN=""                       # Discord bot token
DISCORD_GUILD_ID=""                        # Server (guild) ID — right-click server → Copy ID
DISCORD_CHANNEL_IDS=""                     # Comma-separated channel IDs the bot can respond in
                                           # e.g. "1369573317907845163,1381681418047848549"
                                           # Leave blank = bot can't respond anywhere

# ── Dotfiles ──────────────────────────────────────────────────────────────────
# Your team's dotfiles repo (zsh, vim, git config, etc.)
# Leave blank to skip dotfiles setup entirely.
DOTFILES_REPO=""                           # e.g. "https://github.com/yourorg/server-dotfiles.git"

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Strongly recommended. Get from: Cloudflare Zero Trust → Tunnels → Create Tunnel.
# If set, SSH is restricted to loopback-only (no public port) after tunnel is confirmed.
CLOUDFLARE_TUNNEL_TOKEN=""

# ── WatchClaw security ────────────────────────────────────────────────────────
INSTALL_WATCHCLAW="y"                      # Install WatchClaw? y/n
WATCHCLAW_TELEGRAM_TOKEN=""                # Bot token for security alerts
                                           # (defaults to OPS_TELEGRAM_BOT_TOKEN if blank)
WATCHCLAW_CHAT_ID=""                       # Chat ID for alerts
                                           # (defaults to OPS_TELEGRAM_CHAT_ID if blank)

# ── Hindsight PageIndex ───────────────────────────────────────────────────────
INSTALL_HINDSIGHT="y"                      # Install Hindsight memory indexer? y/n

# ── Docs sync (Hindsight integration) ────────────────────────────────────────
# Set to a git repo SSH URL to auto-index markdown docs into Hindsight.
# Leave blank to skip.
DOCS_SYNC_REPO=""                          # e.g. "git@github.com:yourorg/docs.git"

# ── Dashboard (stub — not yet implemented) ────────────────────────────────────
INSTALL_DASHBOARD="n"                      # Reserved for future Command Center install
